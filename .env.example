# Copy this file to .env and fill values locally. Do not commit .env.
JKS_AGENT_MODE="local"
JKS_AGENT_ENDPOINT="replace-with-agent-endpoint"
JKS_AGENT_TOKEN="replace-with-agent-token"
JKS_AGENT_MODEL="gran-agent"
JKS_AGENT_HOST=""
JKS_AGENT_USER=""
JKS_AGENT_AUTH_METHOD=""
JKS_AGENT_SSH_PASSWORD="replace-with-agent-ssh-password"
JKS_AGENT_COMMAND=".local/bin/jksgrantly"
JKS_AGENT_WORKDIR=".local/hermes-agent"

# Hermes API Server example:
# JKS_AGENT_ENDPOINT="http://127.0.0.1:8642/v1/chat/completions"
# JKS_AGENT_TOKEN="replace-with-api-server-key"

# Hermes SSH/CLI fallback example for a remote Hermes Agent:
# JKS_AGENT_HOST="replace-with-agent-host"
# JKS_AGENT_USER="replace-with-agent-user"
# JKS_AGENT_AUTH_METHOD="ssh-password"
# JKS_AGENT_SSH_PASSWORD="replace-with-ssh-password"
# JKS_AGENT_COMMAND="/usr/local/lib/hermes-agent/venv/bin/hermes"
# JKS_AGENT_WORKDIR="/usr/local/lib/hermes-agent"

JKS_STT_PROVIDER="fish"
JKS_TTS_PROVIDER="fish"
JKS_FISH_API_KEY="replace-with-fish-api-key"
# FISH_AUDIO_API_KEY and FISH_API_KEY are also accepted as aliases.
JKS_FISH_TTS_MODEL="s2-pro"
JKS_FISH_TTS_LATENCY="low"
JKS_TTS_VOICE="default"

# Custom HTTP speech adapter example:
# JKS_STT_PROVIDER="http"
# JKS_STT_ENDPOINT="replace-with-stt-endpoint"
# JKS_STT_TOKEN="replace-with-stt-token"
# JKS_TTS_PROVIDER="http"
# JKS_TTS_ENDPOINT="replace-with-tts-endpoint"
# JKS_TTS_TOKEN="replace-with-tts-token"

JKS_OLED_PORT="replace-with-oled-port"
JKS_OLED_BAUD="115200"
